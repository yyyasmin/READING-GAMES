# Copy to .env and set your PostgreSQL password.
# Database (one for both frontend projects)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/ndfa_games

# Optional: comma-separated frontend origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional
PORT=5000
SECRET_KEY=your-secret-key
ADMIN_SECRET=your-admin-secret
