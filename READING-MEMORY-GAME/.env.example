# אופציונלי: כתובת ה-backend (אם לא מוגדר – localhost:5000 או Render בפרודקשן)
# VITE_BACKEND_URL=http://localhost:5000

# משחק «מלחמה» (CBT): נתיב יחסי = אותו host כמו READING (דרך proxy ב-vite של READING). חובה שגם CBT רץ (npm run dev בפורט 5176).
# לחיבור ישיר לפורט 5176 (ללא proxy): VITE_CBT_GAME_URL=http://localhost:5176
VITE_CBT_GAME_URL=/cbt
