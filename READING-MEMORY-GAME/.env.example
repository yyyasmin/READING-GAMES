# אופציונלי: כתובת ה-backend (אם לא מוגדר – localhost:5000 או Render בפרודקשן)
# VITE_BACKEND_URL=http://localhost:5000

# משחק «מלחמה» (CBT): נתיב יחסי = אותו host כמו READING (דרך proxy ב-vite של READING). חובה שגם CBT רץ (npm run dev בפורט 5176).
# לחיבור ישיר לפורט 5176 (ללא proxy): VITE_CBT_GAME_URL=http://localhost:5176
VITE_CBT_GAME_URL=/cbt

# משחק כדורגל CBT: דרך proxy ב־READING לפורט 5177. לחיבור ישיר: VITE_SOCCER_GAME_URL=http://localhost:5177
VITE_SOCCER_GAME_URL=/soccer

# כדורגל CBT לוח וקלפים — proxy לפורט 5178
VITE_SOCCER_BOARD_GAME_URL=/soccer-board

# כדורגל העצמה — proxy לפורט 5179
VITE_SOCCER_EMPOWER_GAME_URL=/soccer-empower
# פאנל DEBUG ב־Mind Match (אופציונלי; ב־npm run dev מוצג גם בלי זה)
# VITE_DEBUG_BOARD=1
